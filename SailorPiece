					Url = _base .. "/session/check",
					Method = "POST",
					Headers = { ["Content-Type"] = "application/json" },
					Body = _hs:JSONEncode({ userId = _lp.UserId, token = shared._pympleToken or "" }),
				})
				if not _cok then
					_ok, _reason = false, "token expired"
				elseif _res and _res.StatusCode == 200 then
					_ok = true
				else
					_ok, _reason = false, "invalid session"
				end
			else
				_ok, _reason = false, "token expired"
			end
		end
	end
