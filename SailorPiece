fn.OpenAllChests = function()
	if not F.AutoChest then
		return
	end
	if not S.CachedUseItem then
		pcall(function()
			local f = RS:FindFirstChild(R.UseItem[1])
			if f then
				S.CachedUseItem = f:FindFirstChild(R.UseItem[2])
			end
		end)
		if not S.CachedUseItem then
			pcall(function()
				S.CachedUseItem = fn.WalkPathWait(RS, 1, unpack(R.UseItem))
			end)
		end
	end
	local useItem = S.CachedUseItem
	if not useItem then
		return
	end
	local isEvent = false
	pcall(function()
		isEvent = useItem:IsA("RemoteEvent")
	end)
	local startIdx = S.ChestIndex or 0
	local found = false
	for i = 1, #S.ChestNames do
		local idx = (startIdx + i - 1) % #S.ChestNames + 1
		if S.FC[S.ChestNames[idx]] then
			S.ChestIndex = idx
			found = true
			break
		end
	end
	if not found then
		return
	end
	local name = S.ChestNames[S.ChestIndex]
	if isEvent then
		pcall(function()
			useItem:FireServer("Use", name, 999, false)
		end)
	else
		fn.SafeInvoke(useItem, 0.5, "Use", name, 999, false)
	end
	task.wait(0.2)
	fn.ClickYes()
	fn.SuppressHasItemError()
end
