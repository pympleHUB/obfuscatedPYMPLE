		for _, m in ipairs(nf:GetChildren()) do
			if m:IsA("Model") and fn.IsTrueAizenModel(m.Name) then
				local hm = fn.GetHum(m)
				if hm and hm.Health > 0 then
					return m
				end
			end
		end
		return nil
	end
