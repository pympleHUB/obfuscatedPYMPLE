				task.wait(0.06)
				_TS:Create(_rf, TweenInfo.new(0.06), { BackgroundTransparency = 0.88 }):Play()
				task.wait(0.06)
			end
			_TS:Create(_rf, TweenInfo.new(0.2), { BackgroundTransparency = 0 }):Play()
