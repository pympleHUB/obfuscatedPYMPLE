			if d:IsA("TextLabel") or d:IsA("TextButton") then
				local txt = (d.Text or ""):lower()
				if (txt:find("don") or txt:find("doesn")) and txt:find("have") then
					local p = d
					while p and not p:IsA("ScreenGui") do
						p = p.Parent
					end
					if p then
						pcall(function()
							p.Enabled = false
						end)
