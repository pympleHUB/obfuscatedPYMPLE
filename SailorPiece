			local function _syncHub()
				_gwhub.AnchorPoint = _mf.AnchorPoint
				_gwhub.Position = _mf.Position
				_gwhub.Size = _mf.Size
				_gwhub.Visible = _mf.Visible and S._glowEnabled
			end
			_syncHub()
			_mf:GetPropertyChangedSignal("AnchorPoint"):Connect(_syncHub)
			_mf:GetPropertyChangedSignal("Position"):Connect(_syncHub)
			_mf:GetPropertyChangedSignal("Size"):Connect(_syncHub)
			_mf:GetPropertyChangedSignal("Visible"):Connect(_syncHub)

			local _gwrap = Instance.new("Frame")
			_gwrap.BackgroundTransparency = 1
			_gwrap.BorderSizePixel = 0
			_gwrap.AnchorPoint = Vector2.new(0, 0)
			_gwrap.ZIndex = 3
			_gwrap.Parent = _pg

			local function _mkRG(thick, transp)
				local f = Instance.new("Frame")
				f.BackgroundTransparency = 1
				f.BorderSizePixel = 0
				f.AnchorPoint = Vector2.new(0.5, 0.5)
				f.Position = UDim2.fromScale(0.5, 0.5)
				f.Size = UDim2.fromScale(1, 1)
				f.ZIndex = 3
				f.Parent = _gwrap
				Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)
				local s = Instance.new("UIStroke", f)
				s.Color = Color3.fromRGB(220, 60, 60)
				s.Thickness = thick
				s.Transparency = transp
				table.insert(S._rgStrokes, s)
			end
			S._glowBaseTransp = { 0.82, 0.91, 0.95, 0.98 }
			S._glowIntensity = 1
			_mkRG(1.5, S._glowBaseTransp[1])
			_mkRG(4, S._glowBaseTransp[2])
			_mkRG(8, S._glowBaseTransp[3])
			_mkRG(14, S._glowBaseTransp[4])
			S._applyGlowIntensity = function(intensity)
				S._glowIntensity = intensity
				if S._rgStrokes and S._glowBaseTransp then
					for i, s in ipairs(S._rgStrokes) do
						local base = S._glowBaseTransp[i] or 0.9
						s.Transparency = 1 - (1 - base) * intensity
					end
				end
			end
			S._glowWhiteIntensity = 1
			S._applyWhiteIntensity = function(intensity)
				S._glowWhiteIntensity = intensity
				if S._gs then
					S._gs.Transparency = 1 - intensity
				end
			end

			local function _sync()
				local pgAP = _pg.AbsolutePosition
				local mfAP = _mf.AbsolutePosition
				local mfAS = _mf.AbsoluteSize
				local protrude = (_tf and math.max(0, _tf.Size.X.Offset - 25)) or 0
				_gwrap.Position = UDim2.fromOffset(mfAP.X - pgAP.X - protrude, mfAP.Y - pgAP.Y)
				_gwrap.Size = UDim2.fromOffset(mfAS.X + protrude, mfAS.Y)
				_gwrap.Visible = _mf.Visible and S._glowEnabled
			end

			RS.Heartbeat:Wait()
			_sync()
			_mf:GetPropertyChangedSignal("AbsolutePosition"):Connect(_sync)
			_mf:GetPropertyChangedSignal("AbsoluteSize"):Connect(_sync)
			_mf:GetPropertyChangedSignal("Visible"):Connect(_sync)
			if _tf then
				_tf:GetPropertyChangedSignal("Size"):Connect(_sync)
			end
			S._gwrap = _gwrap

			task.spawn(function()
				while _gwhub and _gwhub.Parent do
					_ts:Create(_gg, TweenInfo.new(3, Enum.EasingStyle.Linear), { Rotation = 360 }):Play()
					task.wait(3.05)
