						.. ","
						.. math.floor(desc.Position.Y)
						.. ","
						.. math.floor(desc.Position.Z)
				end
			end)
			local kids = {}
			for _, ch in ipairs(desc:GetChildren()) do
				table.insert(kids, ch.Name .. "[" .. ch.ClassName .. "]")
			end
