				})
				if not _c2 or not _r2 then
					_reOk = false
				elseif _r2.StatusCode == 200 then
					_reOk = true
				elseif _r2.StatusCode == 403 then
					_reOk = false
				else
					_reOk = false
				end
			else
				_reOk = false
			end
			if not _reOk then
				_deny(
					"runtime auth tamper",
					"UNAUTHORIZED! Session tampered. Please re-launch via the official PYMPLE loader!"
				)
				break
			end
		end
	end)
end

