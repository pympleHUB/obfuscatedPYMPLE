			_kl.BackgroundTransparency = 1
			_kl.Text = "ACCESS DENIED"
			_kl.TextColor3 = Color3.fromRGB(255, 255, 255)
			_kl.TextTransparency = 1
			_kl.Font = Enum.Font.GothamBold
			_kl.TextSize = 52
			_kl.ZIndex = 101
			local _ks = Instance.new("UIStroke", _kl)
			_ks.Color = Color3.fromRGB(120, 0, 0)
			_ks.Thickness = 5
			_ks.Transparency = 1
			for _ = 1, 3 do
