fn.IsBossOnCooldown = function(name)
	local dt = S.BossDeathTimes[name]
	if dt and tick() - dt < 30 then
		return true
	end
	local tc = S.BossTimerCache[name]
	if tc and (tick() - (tc.t or 0)) < 5 and not tc.alive then
		return true
	end
