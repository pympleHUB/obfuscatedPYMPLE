		_gs.Color = Color3.fromRGB(255,255,255); _gs.Thickness = 2.5
		local _gg = Instance.new("UIGradient", _gs)
		_gg.Transparency = NumberSequence.new{
			NumberSequenceKeypoint.new(0,0.97), NumberSequenceKeypoint.new(0.12,0),
			NumberSequenceKeypoint.new(0.38,0.75), NumberSequenceKeypoint.new(0.62,0.75),
			NumberSequenceKeypoint.new(0.88,0), NumberSequenceKeypoint.new(1,0.97),
		}
		local function _sync()
			_gw.AnchorPoint=_mf.AnchorPoint _gw.Position=_mf.Position
			_gw.Size=UDim2.new(_mf.Size.X.Scale,_mf.Size.X.Offset+2,_mf.Size.Y.Scale,_mf.Size.Y.Offset+2)
			_gw.Visible=_mf.Visible
		end
		_mf:GetPropertyChangedSignal("Position"):Connect(_sync)
		_mf:GetPropertyChangedSignal("Size"):Connect(_sync)
		_mf:GetPropertyChangedSignal("Visible"):Connect(_sync)
		task.spawn(function()
			while _gw and _gw.Parent do
				_ts:Create(_gg,TweenInfo.new(3,Enum.EasingStyle.Linear),{Rotation=360}):Play()
				task.wait(3.05)
				if _gg and _gg.Parent then _gg.Rotation=0 end
			end
		end)
	end
end

