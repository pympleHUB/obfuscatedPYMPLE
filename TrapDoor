		local TI_FI = TweenInfo.new(0.2,  Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
		activeTabKey = key
		for k, pg in pairs(tabPages) do
			if k == key then
				pg.GroupTransparency = 1
				pg.Visible = true
				TS:Create(pg, TI_FI, {GroupTransparency = 0}):Play()
			else
				TS:Create(pg, TI_FO, {GroupTransparency = 1}):Play()
				task.delay(0.13, function() if pg and pg.Parent then pg.Visible = false end end)
			end
		end
		for k, d in pairs(tabBtns) do
			local on = (k == key)
			TS:Create(d.bg,      TI_A,  {BackgroundTransparency = on and 0.925 or 1}):Play()
			TS:Create(d.iconBox, TI_A,  {BackgroundTransparency = on and 0.95 or 1}):Play()
