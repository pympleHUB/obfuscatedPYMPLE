	for _, _c in ipairs(_pg:GetChildren()) do
		if _c:IsA("Frame") and _c.ZIndex == 4 then _mf = _c break end
	end
	if _mf then
		local _gw = Instance.new("Frame")
		_gw.BackgroundTransparency = 1
		_gw.AnchorPoint = _mf.AnchorPoint
		_gw.Position    = _mf.Position
		_gw.Size        = UDim2.new(_mf.Size.X.Scale, _mf.Size.X.Offset+2, _mf.Size.Y.Scale, _mf.Size.Y.Offset+2)
