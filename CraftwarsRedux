local function DetectBossCutscene()
    if not BossDetected then return false end
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return false end
    for _,g in ipairs(pg:GetDescendants()) do
        if g:IsA("TextLabel") or g:IsA("TextButton") then
            local t = (g.Text or ""):lower()
            if (t:find("tap") and t:find("skip")) or (t:find("skip") and g.Visible and g:IsA("TextButton")) then return true end
        end
    end
    local cg = pg:FindFirstChild("CutsceneGui") or pg:FindFirstChild("BossCutscene") or pg:FindFirstChild("Cutscene") or pg:FindFirstChild("CutsceneFrame")
    if cg and cg.Enabled~=false then return true end
    return LocalPlayer:GetAttribute("InCutscene")==true or LocalPlayer:GetAttribute("Cutscene")==true
end

