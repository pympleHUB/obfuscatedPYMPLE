-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function(dt)
    CooldownTimer,BiomeCheckTimer,CutsceneCheckTimer = CooldownTimer+dt,BiomeCheckTimer+dt,CutsceneCheckTimer+dt
    MeteorTimer,SwingTimer,AbilityTimer,LastAutoSave,GodTimer = MeteorTimer+dt,SwingTimer+dt,AbilityTimer+dt,LastAutoSave+dt,GodTimer+dt
    
    if Flags.AutoSaveEnabled and LastAutoSave>=AutoSaveInterval then LastAutoSave=0 task.spawn(SaveConfig) end
    if Flags.AutoGodSelf and GodTimer>=Flags.AutoGodInterval then GodTimer=0 task.spawn(GodSelf) end
    if CutsceneCheckTimer>=1 then BossDetected=DetectBossPresence() end
    if Flags.AutoSwing and SwingTimer>=Flags.SwingCooldown then SwingTimer=0 PerformSwingAttack() end
    if Flags.AutoAbilities and AbilityTimer>=Flags.AbilityCooldown then AbilityTimer=0 PerformAbilities() end
    
    if Flags.AutoMeteor and MeteorTimer>=Flags.MeteorCooldown then
        MeteorTimer=0
        local w,rf = GetEquippedMeteorWeapon()
        if w and rf then local e=GetNearestEnemy() if e then FireMeteor(rf,e) end end
    end
    
    if Flags.AutoSkipCutscene and BossDetected and CutsceneCheckTimer>=Flags.CutsceneCheckInterval then
        CutsceneCheckTimer=0
        local ic = DetectBossCutscene()
        if ic and not IsInCutscene then
            IsInCutscene=true
            task.spawn(function() task.wait(0.1) SkipBossCutscene() task.wait(0.2) if DetectBossCutscene() then SkipBossCutscene() end end)
        elseif not ic then IsInCutscene=false end
    end
    
    if Flags.AutoBiomeLock and BiomeCheckTimer>=Flags.BiomeCheckInterval then BiomeCheckTimer=0 SummonBiome(Flags.TargetBiome) end
    
    if not Flags.Enabled then return end
    if CooldownTimer<(Flags.AttackCooldown or 0.5) then return end
    local w = GetWeapon()
    if not w then return end
    local rf = w:FindFirstChild("RemoteFunction")
    if not rf then return end
    local hv = GetDamageValue()
    
    if Flags.AutoEnemies then
        for _,m in ipairs(GetAllEnemies()) do
            local h = m:FindFirstChild("Humanoid")
            if h and IsUsableHealth(h.Health) then pcall(function() rf:InvokeServer("hit",{h,hv}) end) end
        end
    end
    
    if Flags.AutoMines and type(Flags.MineTargets)=="table" then
        for mn,sel in pairs(Flags.MineTargets) do
            if sel and type(mn)=="string" then
                local mf = workspace:FindFirstChild(mn)
                if mf then
                    for _,c in ipairs(mf:GetChildren()) do
                        local o = c:FindFirstChild("Ore")
                        if o then
                            local oh = GetOreHealth(o)
                            if oh==nil or IsUsableHealth(oh) then pcall(function() rf:InvokeServer("hit",{o,hv}) end) end
                        end
                    end
                end
            end
        end
    end
    CooldownTimer=0
end)

