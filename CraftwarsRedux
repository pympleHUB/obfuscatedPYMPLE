local function DetectBossPresence()
    for _,m in ipairs(workspace:GetChildren()) do
        if m:IsA("Model") then
            local h = m:FindFirstChild("Humanoid")
            if h and (m:FindFirstChild("EnemyMain") or m:FindFirstChild("BossMain") or IsSpecialBoss(m)) then
                local n = m.Name:lower()
                for _,b in ipairs(BossNames) do if n:find(b:lower()) then return true end end
                if h.MaxHealth and h.MaxHealth>100000 then return true end
            end
        end
    end
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        for _,g in ipairs(pg:GetDescendants()) do
            if g:IsA("TextLabel") then
                local t = g.Text or ""
                for _,b in ipairs(BossNames) do if t:find(b) then return true end end
                if t:match("%[.+%]:") then return true end
            end
        end
    end
    return false
end

