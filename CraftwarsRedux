        local rf = i:FindFirstChild("RemoteFunction")
        if rf then r,rt = rf,"RemoteFunction" end
        local re = i:FindFirstChild("RemoteEvent")
        if re then r,rt = re,"RemoteEvent" end
        for _,c in ipairs(i:GetChildren()) do
            if c.Name:find("Remote") and (c:IsA("RemoteEvent") or c:IsA("RemoteFunction")) then r,rt = c,c.ClassName break end
        end
        if r then table.insert(w,{weapon=i,remote=r,remoteType=rt,name=i.Name}) end
    end
    return w
end

