local function CanUseFileSystem()
    local s = pcall(function() return writefile and readfile and isfile end)
    return s and writefile and readfile and isfile
end

local function SaveConfig()
    if not CanUseFileSystem() then return false end
    local data = {version=CONFIG_VERSION,timestamp=os.time(),settings={}}
    for _,k in ipairs(SaveableKeys) do
        local v = Flags[k]
        if k~="DamageValue" and k~="GodHealthValue" and k~="KillHealthValue" and v~=nil then
            data.settings[k]=v
        end
    end
    return pcall(function() writefile(CONFIG_FILE,HttpService:JSONEncode(data)) end)
end

function ParseDamage(input)
    if not input or input=="" then return math.huge end
    local str = tostring(input):lower():gsub(",",""):gsub(" ","")
    if str=="inf" or str=="infinite" or str=="max" then return math.huge end
    local num,suffix = str:match("^([%d%.]+)([kmbt]?)$")
    if num then
        local v = tonumber(num)
        if v then
            if suffix=="k" then v=v*1e3 elseif suffix=="m" then v=v*1e6
            elseif suffix=="b" then v=v*1e9 elseif suffix=="t" then v=v*1e12 end
            return v
        end
    end
    return tonumber(str) or math.huge
end

local function LoadConfig()
    if not CanUseFileSystem() or not isfile(CONFIG_FILE) then return false end
    local s,r = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
    if not s or not r then return false end
    for k,v in pairs(r.settings or {}) do
        if Flags[k]~=nil and (type(v)==type(Flags[k]) or type(Flags[k])=="number") then Flags[k]=v end
    end
    if Flags.DamageInput then Flags.DamageValue=ParseDamage(Flags.DamageInput) end
    if Flags.GodHealthInput then Flags.GodHealthValue=ParseDamage(Flags.GodHealthInput) end
    if Flags.KillHealthInput then Flags.KillHealthValue=ParseDamage(Flags.KillHealthInput) end
    NameSpoofEnabled,SpoofName = Flags.NameSpoofEnabled,Flags.SpoofName or "pimple"
    return true
end

