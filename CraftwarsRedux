    if CachedArmour and (t-LastArmourCheck)<CACHE_DURATION and CachedArmour.Parent==LocalPlayer.Backpack then return CachedArmour end
    LastArmourCheck,CachedArmour = t,nil
    for _,c in ipairs(LocalPlayer.Backpack:GetChildren()) do
