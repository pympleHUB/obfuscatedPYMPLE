local function IsUsableHealth(h) return type(h)=="number" and h>0 and h==h and math.abs(h)~=math.huge end

local function GetOreHealth(o)
    local s,h = pcall(function() return o.Health end)
    if s and type(h)=="number" then return h end
    local hv = o:FindFirstChild("Health")
    if hv and type(hv.Value)=="number" then return hv.Value end
    local ah = o:GetAttribute("Health")
    return type(ah)=="number" and ah or nil
end

