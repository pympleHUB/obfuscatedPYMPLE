    LastWeaponCheck,CachedWeapon = t,nil
    for _,c in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if c:FindFirstChild("SwordControl") and c:FindFirstChild("RemoteFunction") then CachedWeapon=c return c end
    end
    return nil
end

local function GetArmour()
