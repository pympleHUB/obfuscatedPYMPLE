local function KillAllPlayers(hv)
    local a = GetArmour()
    if not a then return 0 end
    local rf = a:FindFirstChild("RemoteFunction")
    if not rf then return 0 end
    local n = 0
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local c = p.Character
            local h = c and c:FindFirstChild("Humanoid")
            if h and h.Health>0 then pcall(function() rf:InvokeServer("protect",{c,h,-hv}) end) n=n+1 end
            task.wait()
        end
    end
    return n
end

