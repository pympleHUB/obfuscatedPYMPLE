local function GetNearestEnemy()
    local c = LocalPlayer.Character
    if not c then return nil end
    local rp = c:FindFirstChild("HumanoidRootPart")
    if not rp then return nil end
    local ne,nd = nil,math.huge
    for _,m in ipairs(workspace:GetChildren()) do
        if m:IsA("Model") and IsEnemy(m) then
            local h,hd = m:FindFirstChild("Humanoid"),m:FindFirstChild("Head")
            if h and hd and IsUsableHealth(h.Health) then
                local d = (hd.Position-rp.Position).Magnitude
                if d<nd then nd,ne = d,m end
            end
        end
    end
    return ne
end

local function GetAllEnemies()
    local e = {}
    for _,m in ipairs(workspace:GetChildren()) do
        if m:IsA("Model") and IsEnemy(m) then
            local h = m:FindFirstChild("Humanoid")
            if h and IsUsableHealth(h.Health) then table.insert(e,m) end
        end
        if m:IsA("Folder") or m:IsA("Model") then
            for _,c in ipairs(m:GetChildren()) do
                if c:IsA("Model") and IsEnemy(c) then
                    local h = c:FindFirstChild("Humanoid")
                    if h and IsUsableHealth(h.Health) then table.insert(e,c) end
                end
            end
        end
    end
    return e
end

