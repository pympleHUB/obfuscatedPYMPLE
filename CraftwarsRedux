local function FireRemote(wd,a)
    if not wd or not wd.remote then return false end
    if wd.remoteType=="RemoteEvent" or wd.remote:IsA("RemoteEvent") then
        return pcall(function() wd.remote:FireServer(a) end)
    else
        return pcall(function() wd.remote:InvokeServer(a) end)
    end
end

